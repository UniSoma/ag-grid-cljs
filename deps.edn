{:paths ["src/main"]

 ;; Zero runtime dependencies beyond the AG Grid peer packages (ADR 0005 §8):
 ;; the cljs-bean slice is vendored under ag-grid-cljs.impl.bean.
 :deps {}

 :aliases
 {:dev {:extra-paths ["src/dev" "src/test" "src/browser-test"]
        :extra-deps  {thheller/shadow-cljs {:mvn/version "3.4.11"}
                      ;; dev harness only: Fulcro is the reference-consumer
                      ;; bar (ticket agd-01ky0ed8766f), never a library dep
                      com.fulcrologic/fulcro {:mvn/version "3.9.5"}}}

  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.5"}
                 slipset/deps-deploy {:mvn/version "0.2.2"}}
          :ns-default build}}}
